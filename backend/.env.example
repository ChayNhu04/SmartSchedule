# ===========================================================================
# SmartSchedule Backend (NestJS) — Environment Variables
# ===========================================================================
# Copy this file to `.env` and fill in your real values:
#   cp backend/.env.example backend/.env
#
# `.env` is git-ignored (see .gitignore at repo root). Never commit real
# secrets, connection strings, or JWT keys to the repository.
# ===========================================================================

# ---------- Runtime ----------
NODE_ENV=production
PORT=3000

# ---------- Database (PostgreSQL) ----------
# Local dev (docker-compose):
#   DATABASE_URL=postgres://postgres:postgres@db:5432/smartschedule
#   DATABASE_SSL=false
#
# Neon (https://console.neon.tech) — pooled connection, recommended for
# serverless/Railway/Fly. The `?sslmode=require` flag is mandatory; keep
# `DATABASE_SSL=true` so the app accepts Neon's certificate.
DATABASE_URL=postgresql://<user>:<password>@<project>-pooler.<region>.aws.neon.tech/<db>?sslmode=require&channel_binding=require
DATABASE_SSL=true

# ---------- JWT ----------
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-32-byte-random-hex
JWT_EXPIRES_IN=7d

# ---------- CORS ----------
# Comma-separated list of allowed origins, or `*` to allow any origin.
# In production, lock this down to your real web/mobile domains.
#   CORS_ORIGIN=https://app.example.com,https://staging.example.com
CORS_ORIGIN=*

# ---------- Expo Push Notifications ----------
# Optional. Get a token at https://expo.dev/accounts/<you>/settings/access-tokens
# Leave empty to disable push delivery.
EXPO_ACCESS_TOKEN=
