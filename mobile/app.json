{
  "expo": {
    "name": "SmartSchedule",
    "slug": "smartschedule",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "smartschedule",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chaynhu04.smartschedule"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.chaynhu04.smartschedule"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1f6feb"
        }
      ]
    ],
    "experiments": { "typedRoutes": true },
    "extra": {
      "router": { "origin": false }
    }
  }
}
