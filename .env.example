# ===== Backend =====
NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@db:5432/smartschedule
DATABASE_SSL=false

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Expo Push (https://expo.dev/notifications)
EXPO_ACCESS_TOKEN=

# CORS
CORS_ORIGIN=*

# ===== Mobile (mobile/.env) =====
# EXPO_PUBLIC_API_URL=http://localhost:3000/api
