{
  "name": "smartschedule",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "lint": "pnpm -r --parallel run lint",
    "typecheck": "pnpm -r --parallel run typecheck",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "dev:backend": "pnpm --filter smartschedule-backend start:dev",
    "dev:web": "pnpm --filter smartschedule-web dev",
    "dev:mobile": "pnpm --filter smartschedule-mobile start"
  }
}
